---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Resources" activeSection="resources">
  <div class="space-y-6 font-sans">
    
    <!-- Page Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold text-slate-900 tracking-tight">Gated Resources</h1>
        <p class="text-xs text-slate-500 font-light mt-1">Manage downloadable lead magnets and premium checklists.</p>
      </div>
      <div class="flex items-center gap-3">
        <button 
          id="import-json-btn"
          class="inline-flex h-10 px-5 items-center justify-center rounded-xl border border-slate-200 hover:border-slate-850 hover:bg-slate-50 text-slate-700 text-xs font-bold transition shadow-sm cursor-pointer"
        >
          Import from JSON
        </button>
        <a 
          href="/resources/new/" 
          class="inline-flex h-10 px-5 items-center justify-center rounded-xl bg-[#1D9E75] hover:bg-[#0F6E56] text-white text-xs font-bold transition shadow-sm cursor-pointer"
        >
          New Resource &rarr;
        </a>
      </div>
    </div>

    <!-- Table -->
    <div class="w-full overflow-x-auto rounded-2xl border border-slate-200 bg-white shadow-sm">
      <table class="w-full border-collapse text-left text-xs">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20">Title</th>
            <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20">Category</th>
            <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20">Status</th>
            <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20">Updated</th>
            <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20 text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="resource-table-body" class="divide-y divide-slate-100">
          {Array.from({ length: 3 }).map(() => (
            <tr class="animate-pulse">
              <td class="px-6 py-4"><div class="h-3 w-48 bg-slate-100 rounded"></div></td>
              <td class="px-6 py-4"><div class="h-3 w-16 bg-slate-100 rounded"></div></td>
              <td class="px-6 py-4"><div class="h-3 w-12 bg-slate-100 rounded"></div></td>
              <td class="px-6 py-4"><div class="h-3 w-20 bg-slate-100 rounded"></div></td>
              <td class="px-6 py-4 text-right"><div class="h-3 w-24 bg-slate-100 rounded ml-auto"></div></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- JSON Import Modal Overlay -->
    <div id="import-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-xs hidden p-4">
      <div class="w-full max-w-2xl bg-[#0f1117] text-slate-350 border border-slate-800 rounded-2xl shadow-2xl flex flex-col max-h-[90vh] overflow-hidden font-sans">
        <!-- Modal Header -->
        <div class="p-6 border-b border-slate-800/80 flex items-center justify-between">
          <div>
            <h3 class="text-sm font-bold text-white tracking-tight">Import from JSON</h3>
            <p class="text-[10px] text-slate-500 mt-0.5 font-light">Paste a JSON payload to instantly import a new entry.</p>
          </div>
          <button id="modal-close-x" class="text-slate-500 hover:text-white transition cursor-pointer p-1">
            <i class="ti ti-x text-sm"></i>
          </button>
        </div>

        <!-- Modal Body -->
        <div class="p-6 overflow-y-auto space-y-4 flex-grow custom-scrollbar">
          <!-- Textarea Input Area -->
          <div id="modal-input-section" class="space-y-2">
            <textarea
              id="import-json-textarea"
              rows="12"
              class="w-full p-4 rounded-xl border border-slate-850 bg-slate-900/60 text-xs font-mono focus:border-emerald-600 focus:outline-none text-slate-200 leading-relaxed placeholder-slate-600 custom-scrollbar"
            ></textarea>
          </div>

          <!-- Preview Area (Hidden by default) -->
          <div id="modal-preview-section" class="hidden space-y-3">
            <h4 class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Preview Data to Import</h4>
            <div class="overflow-x-auto rounded-xl border border-slate-850 bg-slate-900/40">
              <table class="w-full text-left text-[11px] border-collapse">
                <thead>
                  <tr class="bg-slate-950/60 border-b border-slate-850 text-slate-400">
                    <th class="px-4 py-2.5 font-bold uppercase tracking-wider text-[9px] w-1/4">Field</th>
                    <th class="px-4 py-2.5 font-bold uppercase tracking-wider text-[9px]">Value</th>
                  </tr>
                </thead>
                <tbody id="preview-table-body" class="divide-y divide-slate-850/60 text-slate-300">
                  <!-- dynamically populated -->
                </tbody>
              </table>
            </div>
          </div>

          <!-- Validation Error Message (Hidden by default) -->
          <div id="modal-error-alert" class="hidden p-4 rounded-xl border border-rose-900/50 bg-rose-950/20 text-rose-400 text-[11px] font-medium leading-relaxed">
            <div class="flex gap-2">
              <i class="ti ti-alert-circle text-xs shrink-0 mt-0.5"></i>
              <span id="modal-error-text">JSON validation failed.</span>
            </div>
          </div>
        </div>

        <!-- Modal Footer -->
        <div class="p-6 border-t border-slate-800/80 bg-slate-950/40 flex items-center justify-between">
          <button 
            id="modal-cancel-btn" 
            class="h-10 px-5 border border-slate-800 hover:border-slate-700 hover:bg-slate-900 text-slate-400 font-bold rounded-xl text-xs transition cursor-pointer"
          >
            Cancel
          </button>

          <div class="flex items-center gap-3">
            <button 
              id="modal-preview-btn" 
              class="h-10 px-5 border border-slate-800 hover:border-slate-700 hover:bg-slate-900 text-slate-300 font-bold rounded-xl text-xs transition cursor-pointer"
            >
              Parse & Preview
            </button>
            <button 
              id="modal-confirm-btn" 
              disabled
              class="h-10 px-5 bg-[#1D9E75] hover:bg-[#0F6E56] disabled:opacity-40 disabled:hover:bg-[#1D9E75] text-white font-bold rounded-xl text-xs transition cursor-pointer shadow-sm"
            >
              Confirm Import
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Success Toast Popup -->
    <div 
      id="import-toast" 
      class="fixed bottom-20 right-6 z-50 transform translate-y-12 opacity-0 pointer-events-none transition-all duration-500 bg-emerald-800 text-white px-5 py-3 rounded-xl shadow-xl flex items-center gap-2 text-xs font-bold"
    >
      <i class="ti ti-check text-sm"></i>
      <span id="import-toast-text">Imported successfully!</span>
    </div>

  </div>
</AdminLayout>

<script>
  import { supabase } from '../../lib/supabase';
  import { getResources, deleteResource, saveResource, triggerDeploy } from '../../lib/supabase';

  const RESOURCE_JSON_TEMPLATE = `{
  "title": "Resource Title",
  "slug": "resource-slug",
  "category": "Guide",
  "description": "Short description...",
  "preview_image": "https://drive.google.com/...",
  "bullet_points": ["Point 1", "Point 2", "Point 3"],
  "table_of_contents": ["Chapter 1", "Chapter 2"],
  "excerpt": "Chapter preview text...",
  "locked_content": "## Full markdown content...",
  "cta_headline": "Found this useful?",
  "cta_subtext": "Get notified when we publish more.",
  "target_service_tag": "workflow-automation",
  "estimated_value": "$29 Value",
  "published": true,
  "premium": false
}`;

  function validateResourceJSON(data: any) {
    const errors = [];
    if (!data || typeof data !== 'object') {
      errors.push('JSON must be an object.');
      return errors;
    }
    if (!data.title || typeof data.title !== 'string' || !data.title.trim()) {
      errors.push('Field "title" is required and must be a non-empty string.');
    }
    if (!data.slug || typeof data.slug !== 'string' || !data.slug.trim()) {
      errors.push('Field "slug" is required and must be a non-empty string.');
    } else if (!/^[a-z0-9-_]+$/.test(data.slug)) {
      errors.push('Field "slug" can only contain lowercase letters, numbers, hyphens, and underscores.');
    }
    if (!data.category || typeof data.category !== 'string' || !data.category.trim()) {
      errors.push('Field "category" is required and must be a non-empty string.');
    }
    if (!data.description || typeof data.description !== 'string' || !data.description.trim()) {
      errors.push('Field "description" is required and must be a non-empty string.');
    }
    if (!data.locked_content || typeof data.locked_content !== 'string' || !data.locked_content.trim()) {
      errors.push('Field "locked_content" is required and must be a non-empty string.');
    }
    if (data.bullet_points !== undefined && !Array.isArray(data.bullet_points)) {
      errors.push('Field "bullet_points" must be an array of strings.');
    } else if (Array.isArray(data.bullet_points) && !data.bullet_points.every((t: any) => typeof t === 'string')) {
      errors.push('All items in "bullet_points" array must be strings.');
    }
    if (data.table_of_contents !== undefined && !Array.isArray(data.table_of_contents)) {
      errors.push('Field "table_of_contents" must be an array of strings.');
    } else if (Array.isArray(data.table_of_contents) && !data.table_of_contents.every((t: any) => typeof t === 'string')) {
      errors.push('All items in "table_of_contents" array must be strings.');
    }
    return errors;
  }

  document.addEventListener('DOMContentLoaded', async () => {
    const tbody = document.getElementById('resource-table-body');
    if (!tbody) return;

    // Modal & JSON Import Elements
    const importJsonBtn = document.getElementById('import-json-btn');
    const importModal = document.getElementById('import-modal');
    const modalCloseX = document.getElementById('modal-close-x');
    const importJsonTextarea = document.getElementById('import-json-textarea') as HTMLTextAreaElement | null;
    const modalPreviewBtn = document.getElementById('modal-preview-btn');
    const modalConfirmBtn = document.getElementById('modal-confirm-btn') as HTMLButtonElement | null;
    const modalCancelBtn = document.getElementById('modal-cancel-btn');
    const modalErrorAlert = document.getElementById('modal-error-alert');
    const modalErrorText = document.getElementById('modal-error-text');
    const modalPreviewSection = document.getElementById('modal-preview-section');
    const previewTableBody = document.getElementById('preview-table-body');
    const importToast = document.getElementById('import-toast');
    const importToastText = document.getElementById('import-toast-text');

    if (importJsonTextarea) {
      importJsonTextarea.placeholder = RESOURCE_JSON_TEMPLATE;
    }

    const showToastMsg = (msg: string) => {
      if (!importToast || !importToastText) return;
      importToastText.textContent = msg;
      importToast.classList.remove('opacity-0', 'translate-y-12', 'pointer-events-none');
      importToast.classList.add('opacity-100', 'translate-y-0');
      setTimeout(() => {
        importToast.classList.remove('opacity-100', 'translate-y-0');
        importToast.classList.add('opacity-0', 'translate-y-12', 'pointer-events-none');
      }, 3000);
    };

    const closeModal = () => {
      importModal?.classList.add('hidden');
      if (importJsonTextarea) importJsonTextarea.value = '';
      modalErrorAlert?.classList.add('hidden');
      modalPreviewSection?.classList.add('hidden');
      if (modalConfirmBtn) {
        modalConfirmBtn.disabled = true;
        modalConfirmBtn.textContent = 'Confirm Import';
      }
    };

    importJsonBtn?.addEventListener('click', () => {
      importModal?.classList.remove('hidden');
    });

    modalCloseX?.addEventListener('click', closeModal);
    modalCancelBtn?.addEventListener('click', closeModal);

    let parsedPayload: any = null;

    modalPreviewBtn?.addEventListener('click', () => {
      if (!importJsonTextarea || !modalErrorAlert || !modalErrorText || !modalPreviewSection || !previewTableBody || !modalConfirmBtn) return;

      const rawJson = importJsonTextarea.value.trim();
      if (!rawJson) {
        modalErrorText.textContent = 'Please paste a JSON payload first.';
        modalErrorAlert.classList.remove('hidden');
        modalPreviewSection.classList.add('hidden');
        modalConfirmBtn.disabled = true;
        return;
      }

      try {
        const parsed = JSON.parse(rawJson);
        const errors = validateResourceJSON(parsed);
        if (errors.length > 0) {
          modalErrorText.innerHTML = '<strong>Validation errors found:</strong><ul class="list-disc pl-4 mt-1">' + errors.map(e => `<li>${e}</li>`).join('') + '</ul>';
          modalErrorAlert.classList.remove('hidden');
          modalPreviewSection.classList.add('hidden');
          modalConfirmBtn.disabled = true;
          return;
        }

        modalErrorAlert.classList.add('hidden');
        parsedPayload = parsed;

        const fields = [
          { key: 'title', value: parsed.title },
          { key: 'slug', value: parsed.slug },
          { key: 'category', value: parsed.category },
          { key: 'description', value: parsed.description },
          { key: 'preview_image', value: parsed.preview_image || '(None)' },
          { key: 'cta_headline', value: parsed.cta_headline || '(None)' },
          { key: 'cta_subtext', value: parsed.cta_subtext || '(None)' },
          { key: 'target_service_tag', value: parsed.target_service_tag || '(None)' },
          { key: 'estimated_value', value: parsed.estimated_value || '(None)' },
          { key: 'published', value: parsed.published ? 'Yes' : 'No' },
          { key: 'premium', value: parsed.premium ? 'Yes' : 'No' }
        ];

        previewTableBody.innerHTML = fields.map(f => `
          <tr class="border-b border-slate-850/45 hover:bg-slate-900/25">
            <td class="px-4 py-2 font-semibold text-slate-450">${f.key}</td>
            <td class="px-4 py-2 text-slate-200 truncate max-w-xs">${f.value}</td>
          </tr>
        `).join('');

        modalPreviewSection.classList.remove('hidden');
        modalConfirmBtn.disabled = false;
      } catch (err: any) {
        modalErrorText.textContent = 'Invalid JSON structure: ' + err.message;
        modalErrorAlert.classList.remove('hidden');
        modalPreviewSection.classList.add('hidden');
        modalConfirmBtn.disabled = true;
      }
    });

    modalConfirmBtn?.addEventListener('click', async () => {
      if (!parsedPayload || !modalConfirmBtn || !modalErrorAlert || !modalErrorText) return;

      modalConfirmBtn.disabled = true;
      modalConfirmBtn.textContent = 'Importing...';

      const now = new Date().toISOString();
      const insertData = {
        title: parsedPayload.title,
        slug: parsedPayload.slug,
        category: parsedPayload.category,
        description: parsedPayload.description,
        preview_image: parsedPayload.preview_image || '',
        bullet_points: parsedPayload.bullet_points || [],
        table_of_contents: parsedPayload.table_of_contents || [],
        excerpt: parsedPayload.excerpt || '',
        locked_content: parsedPayload.locked_content,
        cta_headline: parsedPayload.cta_headline || null,
        cta_subtext: parsedPayload.cta_subtext || null,
        target_service_tag: parsedPayload.target_service_tag || '',
        estimated_value: parsedPayload.estimated_value || '',
        published: !!parsedPayload.published,
        premium: !!parsedPayload.premium,
        updated_at: now
      };

      try {
        const { error } = await supabase
          .from('resources')
          .insert([insertData]);

        if (error) {
          if (error.code === '23505' || (error.message && error.message.includes('unique constraint') && error.message.includes('slug'))) {
            modalErrorText.textContent = 'Slug already exists, please change it';
          } else {
            modalErrorText.textContent = 'Import failed. Check console.';
            console.error('Supabase error:', error);
          }
          modalErrorAlert.classList.remove('hidden');
          modalConfirmBtn.disabled = false;
          modalConfirmBtn.textContent = 'Confirm Import';
        } else {
          closeModal();
          showToastMsg('Resource imported successfully!');
          if (insertData.published) {
            await triggerDeploy();
          }
          await loadResources();
        }
      } catch (err: any) {
        modalErrorText.textContent = 'Unexpected error: ' + err.message;
        modalErrorAlert.classList.remove('hidden');
        modalConfirmBtn.disabled = false;
        modalConfirmBtn.textContent = 'Confirm Import';
      }
    });

    const loadResources = async () => {
      tbody.innerHTML = `
        <tr class="animate-pulse">
          <td colspan="5" class="px-6 py-12 text-center text-slate-400">Loading resources...</td>
        </tr>
      `;

      const { data: resources, error } = await getResources();

      if (error) {
        console.error('Failed to load resources:', error);
        tbody.innerHTML = `
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-rose-600 font-semibold bg-rose-50/40">Failed to load resources.</td>
          </tr>
        `;
        return;
      }

      if (!resources || resources.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-slate-400">
              <div class="flex flex-col items-center justify-center space-y-2">
                <i class="ti ti-folder-off text-2xl text-slate-350"></i>
                <span>No resources created yet.</span>
              </div>
            </td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = resources.map(res => {
        const updateDate = res.updated_at 
          ? new Date(res.updated_at).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })
          : 'N/A';
        
        const statusBadge = res.published
          ? `<span class="inline-flex items-center px-2 py-0.5 rounded text-[9px] font-bold bg-emerald-50 text-emerald-800 border border-emerald-100">Published</span>`
          : `<span class="inline-flex items-center px-2 py-0.5 rounded text-[9px] font-bold bg-slate-150 text-slate-500 border border-slate-200/50">Draft</span>`;

        const toggleLabel = res.published ? 'Unpublish' : 'Publish';

        return `
          <tr class="hover:bg-slate-50/70 transition-colors">
            <td class="px-6 py-4 text-slate-900 font-semibold max-w-sm truncate">${res.title}</td>
            <td class="px-6 py-4 text-slate-655 font-medium">${res.category || 'Uncategorized'}</td>
            <td class="px-6 py-4">${statusBadge}</td>
            <td class="px-6 py-4 text-slate-450">${updateDate}</td>
            <td class="px-6 py-4 text-right space-x-1.5 shrink-0 whitespace-nowrap">
              <button 
                data-action="toggle-publish" 
                data-id="${res.id}" 
                data-title="${res.title}"
                data-published="${res.published}"
                class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold border border-slate-200 bg-slate-50 text-slate-700 hover:bg-slate-800 hover:text-white hover:border-slate-800 transition cursor-pointer"
              >
                ${toggleLabel}
              </button>
              <a 
                href="/resources/edit/?id=${res.id}"
                class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold border border-emerald-200 bg-emerald-50 text-emerald-800 hover:bg-[#1D9E75] hover:text-white hover:border-[#1D9E75] transition"
              >
                Edit
              </a>
              <button 
                data-action="delete" 
                data-id="${res.id}"
                data-title="${res.title}"
                class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold border border-rose-200 bg-rose-50 text-rose-800 hover:bg-rose-600 hover:text-white hover:border-rose-600 transition cursor-pointer"
              >
                Delete
              </button>
            </td>
          </tr>
        `;
      }).join('');
    };

    // Table action delegation
    tbody.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('button');
      if (!btn) return;

      const action = btn.getAttribute('data-action');
      const id = btn.getAttribute('data-id') || '';
      const title = btn.getAttribute('data-title') || '';

      if (action === 'delete') {
        if (confirm(`Are you sure you want to delete "${title}"?`)) {
          btn.disabled = true;
          btn.textContent = 'Deleting...';
          const { error } = await deleteResource(id);
          if (error) {
            alert('Failed: ' + error.message);
            btn.disabled = false;
            btn.textContent = 'Delete';
          } else {
            await loadResources();
          }
        }
      }

      if (action === 'toggle-publish') {
        const isPublished = btn.getAttribute('data-published') === 'true';
        btn.disabled = true;
        btn.textContent = isPublished ? 'Unpublishing...' : 'Publishing...';
        
        const { error } = await saveResource({ published: !isPublished }, id);
        if (error) {
          alert('Failed: ' + error.message);
          btn.disabled = false;
          btn.textContent = isPublished ? 'Unpublish' : 'Publish';
        } else {
          if (!isPublished) await triggerDeploy();
          await loadResources();
        }
      }
    });

    await loadResources();
  });
</script>
