---
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Login" publicPage={true}>
  <div class="min-h-screen bg-slate-50 flex flex-col items-center justify-center p-4 font-sans select-none">
    
    <!-- Login Card -->
    <div class="w-full max-w-[420px] bg-white rounded-2xl border border-slate-200/60 p-8 shadow-lg space-y-6 flex flex-col items-center">
      
      <!-- Logo Header -->
      <div class="flex flex-col items-center space-y-1">
        <div class="text-2xl font-extrabold text-slate-950 tracking-tight font-display">
          smesh<span class="text-[#1D9E75]">.dev</span>
        </div>
        <div class="text-[10px] font-bold uppercase tracking-widest text-slate-400 font-mono">
          Admin Dashboard
        </div>
      </div>

      <!-- State 1: Login Form -->
      <div id="login-state-form" class="w-full space-y-5">
        <div class="text-center space-y-1.5">
          <h1 class="text-lg font-bold text-slate-900">Sign In</h1>
          <p class="text-xs text-slate-500 font-light leading-relaxed">
            Enter your email and password to access the portal.
          </p>
        </div>

        <form id="login-form" class="space-y-4">
          <div>
            <label for="email" class="sr-only">Email Address</label>
            <input 
              type="email" 
              id="email" 
              required 
              placeholder="your@email.com" 
              class="w-full h-12 px-4 rounded-xl border border-slate-200 bg-slate-50/50 text-xs focus:border-emerald-600 focus:bg-white focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition"
            />
          </div>

          <div>
            <label for="password" class="sr-only">Password</label>
            <input 
              type="password" 
              id="password" 
              required 
              placeholder="••••••••" 
              class="w-full h-12 px-4 rounded-xl border border-slate-200 bg-slate-50/50 text-xs focus:border-emerald-600 focus:bg-white focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition"
            />
          </div>

          <button 
            type="submit" 
            id="submit-btn" 
            class="w-full h-12 bg-[#1D9E75] hover:bg-[#0F6E56] text-white font-bold rounded-xl text-xs transition flex items-center justify-center gap-2 cursor-pointer shadow-sm"
          >
            <span id="submit-text">Sign In</span>
            <!-- Spinner -->
            <svg id="submit-spinner" class="hidden animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
        </form>

        <!-- Inline Error Container -->
        <div id="error-message" class="hidden text-center text-xs text-rose-600 font-semibold bg-rose-50 border border-rose-100 py-2.5 rounded-xl">
          Something went wrong. Try again.
        </div>
      </div>

    </div>
  </div>
</AdminLayout>

<script>
  import { supabase, signInWithPassword } from '../lib/supabase';

  document.addEventListener('DOMContentLoaded', async () => {
    // 1. Session Redirect Guard
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      if (session.user?.email === 'oxixxa@gmail.com') {
        window.location.href = '/dashboard';
        return;
      } else {
        await supabase.auth.signOut();
      }
    }

    const stateForm = document.getElementById('login-state-form');
    const form = document.getElementById('login-form') as HTMLFormElement | null;
    const emailInput = document.getElementById('email') as HTMLInputElement | null;
    const passwordInput = document.getElementById('password') as HTMLInputElement | null;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const submitText = document.getElementById('submit-text');
    const spinner = document.getElementById('submit-spinner');
    const errorMessage = document.getElementById('error-message');

    if (!form || !emailInput || !passwordInput || !submitBtn || !stateForm) return;

    // 2. Submit Handler
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      const password = passwordInput.value;
      if (!email || !password) return;

      // Show Loading State
      if (errorMessage) errorMessage.classList.add('hidden');
      submitBtn.disabled = true;
      if (submitText) submitText.textContent = 'Signing In...';
      if (spinner) spinner.classList.remove('hidden');

      if (email.toLowerCase() !== 'oxixxa@gmail.com') {
        setTimeout(() => {
          if (errorMessage) {
            errorMessage.textContent = 'Access denied. Unauthorized email.';
            errorMessage.classList.remove('hidden');
          }
          submitBtn.disabled = false;
          if (submitText) submitText.textContent = 'Sign In';
          if (spinner) spinner.classList.add('hidden');
        }, 500);
        return;
      }

      try {
        const { error } = await signInWithPassword(email, password);
        if (error) throw error;

        // Redirect to dashboard on success
        window.location.href = '/dashboard';
      } catch (err: any) {
        console.error('Login request failed:', err);
        // Show inline error
        if (errorMessage) {
          errorMessage.textContent = err?.message || 'Invalid email or password.';
          errorMessage.classList.remove('hidden');
        }
        // Revert submit button
        submitBtn.disabled = false;
        if (submitText) submitText.textContent = 'Sign In';
        if (spinner) spinner.classList.add('hidden');
      }
    });
  });
</script>

<style>
  /* Subtle transition animation */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out forwards;
  }
</style>
