---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

export async function getStaticPaths() {
  const { data } = await supabase
    .from('blog_posts')
    .select('id');
  
  return (data || []).map((p) => ({
    params: { id: p.id }
  }));
}

const { id } = Astro.params;
---

<AdminLayout title="Edit Blog Post" activeSection="blog">
  <div class="space-y-6 font-sans pb-24 relative" id="edit-post-root" data-id={id}>
    
    <!-- Top Nav Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold text-slate-900 tracking-tight">Edit Blog Post</h1>
        <p class="text-xs text-slate-500 font-light mt-1">Modify your article blueprint.</p>
      </div>
    </div>

    <!-- Main Editor Form (Initial loading skeleton cover) -->
    <div id="loading-overlay" class="bg-white border border-slate-200 rounded-2xl p-12 text-center text-slate-400 space-y-3">
      <svg class="animate-spin h-6 w-6 text-[#1D9E75] mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <p class="text-xs font-semibold">Retrieving article details...</p>
    </div>

    <!-- Actual form, hidden during load -->
    <form id="post-editor-form" class="hidden space-y-6">
      
      <!-- Row 1: Title -->
      <div class="space-y-1">
        <label for="post-title" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Article Title</label>
        <input 
          type="text" 
          id="post-title" 
          required 
          placeholder="Enter a catchy, value-driven title..." 
          class="w-full h-[52px] px-5 rounded-2xl border border-slate-200 text-lg font-bold focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition shadow-xs"
        />
      </div>

      <!-- Row 2: Slug & Category -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-1">
          <label for="post-slug" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">URL Slug</label>
          <div class="flex gap-2">
            <input 
              type="text" 
              id="post-slug" 
              required 
              placeholder="auto-generated-from-title" 
              class="flex-1 h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
            />
            <button 
              type="button" 
              id="generate-slug-btn" 
              class="px-4 h-11 bg-slate-100 hover:bg-slate-200 border border-slate-200 text-slate-700 font-bold rounded-xl text-xs transition cursor-pointer"
            >
              Generate
            </button>
          </div>
        </div>
        <div class="space-y-1">
          <label for="post-category" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Category</label>
          <select 
            id="post-category" 
            required 
            class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
          >
            <option value="Automation">Automation</option>
            <option value="Development">Development</option>
            <option value="Business">Business</option>
            <option value="Marketing">Marketing</option>
            <option value="Other">Other</option>
          </select>
        </div>
      </div>

      <!-- Row 3: SEO Title Tag & SEO Description -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-1">
          <label for="post-seo-title" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">SEO Title Tag (Google Search Headline)</label>
          <input 
            type="text" 
            id="post-seo-title" 
            placeholder="If left blank, defaults to Title" 
            class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
          />
        </div>
        <div class="space-y-1">
          <label for="post-seo-desc" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">SEO Meta Description</label>
          <input 
            type="text" 
            id="post-seo-desc" 
            placeholder="Google search snippet..." 
            class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
          />
        </div>
      </div>

      <!-- Row 3.5: Meta Title & Meta Description -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-1">
          <label for="post-meta-title" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Meta Title</label>
          <input 
            type="text" 
            id="post-meta-title" 
            placeholder="Enter Meta Title..." 
            class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
          />
        </div>
        <div class="space-y-1">
          <div class="flex justify-between items-center">
            <label for="post-meta-desc" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Meta Description</label>
            <span id="meta-desc-counter" class="text-[9px] font-bold text-slate-400 font-mono">0/155</span>
          </div>
          <textarea 
            id="post-meta-desc" 
            rows="2"
            maxlength="155"
            placeholder="Enter Meta Description..." 
            class="w-full p-3 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50 font-sans"
          ></textarea>
        </div>
      </div>

      <!-- Row 4: Tags & Cover Image URL/Alt -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-1">
          <label for="post-tags" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Tags (comma-separated)</label>
          <input 
            type="text" 
            id="post-tags" 
            placeholder="n8n, webhook, local-pos" 
            class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
          />
        </div>
        <div class="space-y-1">
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1">
              <label for="post-cover" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Cover Image URL</label>
              <input 
                type="text" 
                id="post-cover" 
                placeholder="/assets/images/blog/cover-file.webp" 
                class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
              />
            </div>
            <div class="space-y-1">
              <label for="post-cover-alt" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Cover Image Alt</label>
              <input 
                type="text" 
                id="post-cover-alt" 
                placeholder="Description of the cover image" 
                class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Row 4.8: Related Case Study Slug & Reading Time -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-1">
          <label for="post-related-case-study" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Related Case Study Slug (optional)</label>
          <input 
            type="text" 
            id="post-related-case-study" 
            placeholder="agency-website-automation" 
            class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
          />
          <p class="text-[10px] text-slate-450 font-light mt-0.5">Agar is blog post ka related case study/portfolio hai to uska slug yahan daalo. Ye end mein "Strategic Case Study" box mein dikhayega.</p>
        </div>
        <div class="space-y-1">
          <label for="post-reading-time" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Reading Time (minutes)</label>
          <input 
            type="number" 
            id="post-reading-time" 
            min="1"
            value="5" 
            class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
          />
        </div>
      </div>

      <!-- Row 4.9: Author Info -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="space-y-1">
          <label for="post-author-name" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Author Name</label>
          <input 
            type="text" 
            id="post-author-name" 
            value="Haider Ali"
            class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
          />
        </div>
        <div class="space-y-1">
          <label for="post-author-avatar" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Author Avatar URL</label>
          <input 
            type="text" 
            id="post-author-avatar" 
            value="/assets/images/resources/author-haider-ali.webp"
            class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50"
          />
        </div>
        <div class="space-y-1">
          <label for="post-author-bio" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Author Bio</label>
          <textarea 
            id="post-author-bio" 
            rows="1"
            class="w-full p-3 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50 font-sans"
          >Haider Ali is an expert automation engineer specializing in building custom n8n pipelines, designing relational Supabase databases, training RAG-powered support chatbots, and building high-speed static websites for businesses across Pakistan and internationally.</textarea>
        </div>
      </div>

      <!-- Row 4.95: Status, Featured & Published At -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="space-y-1">
          <label for="post-status" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Status</label>
          <select 
            id="post-status" 
            class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50 font-semibold text-slate-700"
          >
            <option value="draft">Draft</option>
            <option value="published">Published</option>
          </select>
        </div>
        <div class="space-y-1">
          <label for="post-published-at" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Published At</label>
          <input 
            type="datetime-local" 
            id="post-published-at" 
            class="w-full h-11 px-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50 text-slate-750"
          />
        </div>
        <div class="flex items-center">
          <div class="flex items-center gap-2 p-4 bg-slate-100/50 rounded-xl border border-slate-200/50 w-full select-none font-sans mt-3.5">
            <input 
              type="checkbox" 
              id="post-featured" 
              class="h-4 w-4 rounded text-emerald-600 border-slate-350 focus:ring-[#1D9E75]/25"
            />
            <label for="post-featured" class="text-xs font-bold text-slate-800 cursor-pointer">Featured Post</label>
          </div>
        </div>
      </div>

      <!-- Row 4.98: FAQ Schema (JSON Array) -->
      <div class="space-y-1">
        <label for="post-faq" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">FAQ Schema (JSON Array)</label>
        <textarea 
          id="post-faq" 
          rows="3" 
          placeholder='[{"question":"...","answer":"..."}]' 
          class="w-full p-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50 font-mono"
        ></textarea>
        <p class="text-[10px] text-slate-455 font-light mt-0.5">Enter JSON array of FAQ objects</p>
      </div>

      <!-- Row 5: Excerpt -->
      <div class="space-y-1">
        <label for="post-excerpt" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Excerpt (Teaser paragraph - first 15% of the hook)</label>
        <textarea 
          id="post-excerpt" 
          rows="2" 
          placeholder="Write a compelling introductory summary..." 
          class="w-full p-4 rounded-xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50 font-sans"
        ></textarea>
      </div>

      <!-- Row 6: Content Markdown Monospace Textarea -->
      <div class="space-y-1">
        <div class="flex items-center justify-between">
          <label for="post-content" class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Body Content (Markdown)</label>
          
          <button 
            type="button" 
            id="preview-toggle-btn"
            class="text-[10px] font-bold text-indigo-650 hover:text-indigo-850 hover:underline transition cursor-pointer"
          >
            Show Preview
          </button>
        </div>

        <div class="grid grid-cols-1 gap-6" id="editor-preview-container">
          <textarea 
            id="post-content" 
            rows="20" 
            placeholder="# Introduction\nType markdown body here..." 
            class="w-full p-5 rounded-2xl border border-slate-200 text-xs focus:border-emerald-600 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition bg-slate-50/50 font-mono leading-relaxed"
          ></textarea>

          <div 
            id="preview-panel" 
            class="hidden w-full p-6 bg-white border border-slate-200 rounded-2xl overflow-y-auto max-h-[500px] prose prose-sm content-body"
          >
            <p class="text-slate-400 italic text-xs">Nothing to preview yet.</p>
          </div>
        </div>
      </div>

    </form>

    <!-- Success/Auto-saved Message indicator -->
    <div class="flex items-center gap-2 text-[10px] text-slate-450 select-none font-medium h-4 justify-end">
      <span id="autosave-indicator"></span>
    </div>

    <!-- Bottom Sticky Action Bar -->
    <div class="fixed bottom-0 left-0 right-0 md:left-60 bg-white/90 backdrop-blur-md border-t border-slate-200/80 px-6 py-4 flex items-center justify-between z-40 shadow-lg">
      <a 
        href="/blog/" 
        class="text-xs font-bold text-slate-600 hover:text-slate-900 transition flex items-center gap-1.5"
      >
        <i class="ti ti-arrow-left text-xs"></i> Back to Posts
      </a>

      <div class="flex items-center gap-3">
        <!-- Export as JSON Button -->
        <button 
          type="button" 
          id="export-btn"
          class="h-10 px-4 border border-slate-200 hover:border-slate-800 hover:bg-slate-50 text-slate-700 font-bold rounded-xl text-xs transition cursor-pointer flex items-center gap-1.5"
        >
          <i class="ti ti-download text-xs"></i> Export as JSON
        </button>

        <!-- Save as Draft Button -->
        <button 
          type="button" 
          id="draft-btn"
          class="h-10 px-5 border border-slate-200 hover:border-slate-800 hover:bg-slate-50 text-slate-700 font-bold rounded-xl text-xs transition cursor-pointer"
        >
          Save as Draft
        </button>

        <!-- Save & Publish Button -->
        <button 
          type="button" 
          id="publish-btn"
          class="h-10 px-5 bg-[#1D9E75] hover:bg-[#0F6E56] text-white font-bold rounded-xl text-xs transition cursor-pointer shadow-sm"
        >
          Save & Publish
        </button>
      </div>
    </div>

    <!-- Success Toast Popups -->
    <div 
      id="save-toast" 
      class="fixed bottom-20 right-6 z-50 transform translate-y-12 opacity-0 pointer-events-none transition-all duration-500 bg-slate-900 text-white px-5 py-3 rounded-xl shadow-xl flex items-center gap-2 text-xs font-bold font-sans"
    >
      <i class="ti ti-check text-emerald-500 text-sm"></i>
      <span>Saved!</span>
    </div>

  </div>
</AdminLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<script>
  import { getBlog, saveBlog, triggerDeploy } from '../../lib/supabase';

  document.addEventListener('DOMContentLoaded', async () => {
    const root = document.getElementById('edit-post-root');
    const loadingOverlay = document.getElementById('loading-overlay');
    const form = document.getElementById('post-editor-form') as HTMLFormElement | null;
    const titleInput = document.getElementById('post-title') as HTMLInputElement | null;
    const slugInput = document.getElementById('post-slug') as HTMLInputElement | null;
    const generateSlugBtn = document.getElementById('generate-slug-btn');
    const categoryInput = document.getElementById('post-category') as HTMLSelectElement | null;
    const seoTitleInput = document.getElementById('post-seo-title') as HTMLInputElement | null;
    const seoDescInput = document.getElementById('post-seo-desc') as HTMLInputElement | null;
    const metaTitleInput = document.getElementById('post-meta-title') as HTMLInputElement | null;
    const metaDescInput = document.getElementById('post-meta-desc') as HTMLTextAreaElement | null;
    const metaDescCounter = document.getElementById('meta-desc-counter');
    const faqInput = document.getElementById('post-faq') as HTMLTextAreaElement | null;
    const featuredInput = document.getElementById('post-featured') as HTMLInputElement | null;
    const tagsInput = document.getElementById('post-tags') as HTMLInputElement | null;
    const coverInput = document.getElementById('post-cover') as HTMLInputElement | null;
    const coverAltInput = document.getElementById('post-cover-alt') as HTMLInputElement | null;
    const excerptInput = document.getElementById('post-excerpt') as HTMLTextAreaElement | null;
    const contentInput = document.getElementById('post-content') as HTMLTextAreaElement | null;
    const relatedCaseStudyInput = document.getElementById('post-related-case-study') as HTMLInputElement | null;
    const readingTimeInput = document.getElementById('post-reading-time') as HTMLInputElement | null;
    const authorNameInput = document.getElementById('post-author-name') as HTMLInputElement | null;
    const authorAvatarInput = document.getElementById('post-author-avatar') as HTMLInputElement | null;
    const authorBioInput = document.getElementById('post-author-bio') as HTMLTextAreaElement | null;
    const statusInput = document.getElementById('post-status') as HTMLSelectElement | null;
    const publishedAtInput = document.getElementById('post-published-at') as HTMLInputElement | null;

    const previewToggle = document.getElementById('preview-toggle-btn');
    const container = document.getElementById('editor-preview-container');
    const previewPanel = document.getElementById('preview-panel');
    const toast = document.getElementById('save-toast');
    const autosaveIndicator = document.getElementById('autosave-indicator');

    const draftBtn = document.getElementById('draft-btn') as HTMLButtonElement | null;
    const publishBtn = document.getElementById('publish-btn') as HTMLButtonElement | null;
    const exportBtn = document.getElementById('export-btn');

    if (!root || !form || !titleInput || !slugInput || !contentInput || !draftBtn || !publishBtn || !container || !previewPanel || !loadingOverlay) return;

    const id = root.getAttribute('data-id') || '';

    // Meta Description counter handler
    metaDescInput?.addEventListener('input', () => {
      if (metaDescCounter) {
        metaDescCounter.textContent = `${metaDescInput.value.length}/155`;
      }
    });

    // 1. Fetch Existing Post Data
    const loadPostData = async () => {
      const { data: post, error } = await getBlog(id);
      if (error || !post) {
        console.error('Failed to load post:', error);
        loadingOverlay.innerHTML = `
          <div class="text-rose-600 font-semibold bg-rose-50 border border-rose-100 py-4 px-6 rounded-xl inline-block">
            Error: Failed to load post details.
          </div>
        `;
        return;
      }

      // Populate Form Fields
      titleInput.value = post.title || '';
      slugInput.value = post.slug || '';
      if (categoryInput) {
        categoryInput.value = post.category || 'Automation';
      }
      seoTitleInput.value = post.seo_title || '';
      seoDescInput.value = post.seo_description || '';
      if (metaTitleInput) metaTitleInput.value = post.meta_title || '';
      if (metaDescInput) {
        metaDescInput.value = post.meta_description || '';
        if (metaDescCounter) metaDescCounter.textContent = `${metaDescInput.value.length}/155`;
      }
      if (faqInput) {
        faqInput.value = post.faq_schema ? JSON.stringify(post.faq_schema, null, 2) : '';
      }
      if (featuredInput) {
        featuredInput.checked = !!post.featured;
      }
      tagsInput.value = (post.tags || []).join(', ');
      coverInput.value = post.cover_image || '';
      if (coverAltInput) coverAltInput.value = post.cover_image_alt || '';
      excerptInput.value = post.excerpt || '';
      contentInput.value = post.content || '';
      if (relatedCaseStudyInput) {
        relatedCaseStudyInput.value = post.related_case_study_slug || '';
      }
      if (readingTimeInput) {
        readingTimeInput.value = String(post.reading_time || 5);
      }
      if (authorNameInput) authorNameInput.value = post.author_name || 'Haider Ali';
      if (authorAvatarInput) authorAvatarInput.value = post.author_avatar || '/assets/images/resources/author-haider-ali.webp';
      if (authorBioInput) authorBioInput.value = post.author_bio || '';
      if (statusInput) {
        statusInput.value = post.status || (post.published ? 'published' : 'draft');
      }
      if (publishedAtInput) {
        if (post.published_at) {
          const dateVal = new Date(post.published_at);
          dateVal.setMinutes(dateVal.getMinutes() - dateVal.getTimezoneOffset());
          publishedAtInput.value = dateVal.toISOString().slice(0, 16);
        } else {
          publishedAtInput.value = '';
        }
      }

      // Reveal form
      loadingOverlay.classList.add('hidden');
      form.classList.remove('hidden');

      // Initialize auto-save states
      lastContent = contentInput.value;
      lastTitle = titleInput.value;
    };

    // 2. Slug auto-generation guard
    let isSlugEdited = true;
    slugInput.addEventListener('input', () => {
      isSlugEdited = true;
    });

    const generateSlug = () => {
      slugInput.value = titleInput.value
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/\s+/g, '-');
    };

    generateSlugBtn?.addEventListener('click', generateSlug);

    titleInput.addEventListener('input', () => {
      if (!isSlugEdited || !slugInput.value) {
        generateSlug();
      }
    });

    // 3. Preview toggle
    let isPreviewOn = false;
    previewToggle?.addEventListener('click', () => {
      isPreviewOn = !isPreviewOn;
      if (isPreviewOn) {
        previewToggle.textContent = 'Hide Preview';
        previewPanel.classList.remove('hidden');
        container.classList.remove('grid-cols-1');
        container.classList.add('md:grid-cols-2');
        updatePreview();
      } else {
        previewToggle.textContent = 'Show Preview';
        previewPanel.classList.add('hidden');
        container.classList.remove('md:grid-cols-2');
        container.classList.add('grid-cols-1');
      }
    });

    const updatePreview = () => {
      if (!isPreviewOn || !previewPanel) return;
      const markdownText = contentInput.value;
      if (typeof (window as any).marked !== 'undefined') {
        previewPanel.innerHTML = (window as any).marked.parse(markdownText || '');
      } else {
        previewPanel.textContent = markdownText;
      }
    };

    contentInput.addEventListener('input', updatePreview);

    // 4. Save handler
    const showToast = (msg = 'Saved!') => {
      if (!toast) return;
      const span = toast.querySelector('span');
      if (span) span.textContent = msg;
      
      toast.classList.remove('opacity-0', 'translate-y-12', 'pointer-events-none');
      toast.classList.add('opacity-100', 'translate-y-0');

      setTimeout(() => {
        toast.classList.remove('opacity-100', 'translate-y-0');
        toast.classList.add('opacity-0', 'translate-y-12', 'pointer-events-none');
      }, 3000);
    };

    let isSaving = false;

    const savePost = async (publishState: boolean, silent = false) => {
      if (isSaving) return;

      const title = titleInput.value.trim();
      const slug = slugInput.value.trim();

      if (!title || !slug) {
        if (!silent) alert('Title and Slug are required.');
        return;
      }

      if (!silent) {
        isSaving = true;
        draftBtn.disabled = true;
        publishBtn.disabled = true;
      }

      if (statusInput) {
        statusInput.value = publishState ? 'published' : 'draft';
      }

      const tags = (tagsInput?.value || '')
        .split(',')
        .map(t => t.trim())
        .filter(Boolean);

      let faq_schema = null;
      let isValidFaq = true;
      const faqVal = faqInput?.value.trim() || '';
      if (faqVal) {
        try {
          faq_schema = JSON.parse(faqVal);
        } catch (err: any) {
          isValidFaq = false;
          if (!silent) {
            alert('Invalid JSON in FAQ Schema: ' + err.message);
            isSaving = false;
            draftBtn.disabled = false;
            publishBtn.disabled = false;
            return;
          }
        }
      }

      const nowStr = new Date().toISOString();
      let published_at = publishedAtInput?.value ? new Date(publishedAtInput.value).toISOString() : null;
      if (publishState && !published_at) {
        published_at = nowStr;
        if (publishedAtInput) {
          const localNow = new Date();
          localNow.setMinutes(localNow.getMinutes() - localNow.getTimezoneOffset());
          publishedAtInput.value = localNow.toISOString().slice(0, 16);
        }
      }

      const payload: any = {
        title,
        slug,
        category: categoryInput?.value || 'Automation',
        seo_title: seoTitleInput?.value.trim() || title,
        seo_description: seoDescInput?.value.trim() || excerptInput?.value.trim() || '',
        meta_title: metaTitleInput?.value.trim() || null,
        meta_description: metaDescInput?.value.trim() || null,
        featured: featuredInput ? featuredInput.checked : false,
        tags,
        cover_image: coverInput?.value.trim() || '',
        cover_image_alt: coverAltInput?.value.trim() || null,
        excerpt: excerptInput?.value.trim() || '',
        content: contentInput.value,
        published: publishState,
        related_case_study_slug: relatedCaseStudyInput?.value.trim() || null,
        reading_time: readingTimeInput?.value ? Number(readingTimeInput.value) : 5,
        author_name: authorNameInput?.value.trim() || 'Haider Ali',
        author_avatar: authorAvatarInput?.value.trim() || '/assets/images/resources/author-haider-ali.webp',
        author_bio: authorBioInput?.value.trim() || '',
        status: publishState ? 'published' : 'draft',
        published_at,
        last_modified: nowStr
      };

      if (isValidFaq) {
        payload.faq_schema = faq_schema;
      }

      try {
        const { error } = await saveBlog(payload, id);
        if (error) throw error;

        if (!silent) {
          showToast(publishState ? 'Published successfully!' : 'Saved successfully!');
          
          if (publishState) {
            await triggerDeploy();
          }

          setTimeout(() => {
            window.location.href = '/blog/';
          }, 1500);
        } else {
          const now = new Date().toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit', second: '2-digit' });
          if (autosaveIndicator) {
            autosaveIndicator.textContent = `Auto-saved at ${now}`;
          }
        }
      } catch (err: any) {
        console.error('Failed to save post:', err);
        if (!silent) {
          alert('Failed to save: ' + err.message);
        }
      } finally {
        if (!silent) {
          isSaving = false;
          draftBtn.disabled = false;
          publishBtn.disabled = false;
        }
      }
    };

    draftBtn.addEventListener('click', () => savePost(false));
    publishBtn.addEventListener('click', () => savePost(true));

    // 5. Export Post as JSON
    exportBtn?.addEventListener('click', () => {
      const title = titleInput.value.trim();
      const slug = slugInput.value.trim();

      const tags = (tagsInput?.value || '')
        .split(',')
        .map(t => t.trim())
        .filter(Boolean);

      let faq_schema = null;
      try {
        faq_schema = faqInput?.value.trim() ? JSON.parse(faqInput.value.trim()) : null;
      } catch (e) {}

      const exportData = {
        title,
        slug,
        category: categoryInput?.value || 'Automation',
        seo_title: seoTitleInput?.value.trim() || title,
        seo_description: seoDescInput?.value.trim() || excerptInput?.value.trim() || '',
        meta_title: metaTitleInput?.value.trim() || null,
        meta_description: metaDescInput?.value.trim() || null,
        featured: !!featuredInput?.checked,
        tags,
        cover_image: coverInput?.value.trim() || '',
        cover_image_alt: coverAltInput?.value.trim() || null,
        excerpt: excerptInput?.value.trim() || '',
        content: contentInput.value,
        published: statusInput?.value === 'published',
        faq_schema,
        related_case_study_slug: relatedCaseStudyInput?.value.trim() || null,
        reading_time: readingTimeInput?.value ? Number(readingTimeInput.value) : 5,
        author_name: authorNameInput?.value.trim() || 'Haider Ali',
        author_avatar: authorAvatarInput?.value.trim() || '/assets/images/resources/author-haider-ali.webp',
        author_bio: authorBioInput?.value.trim() || '',
        status: statusInput?.value || 'draft',
        published_at: publishedAtInput?.value ? new Date(publishedAtInput.value).toISOString() : null
      };

      const jsonStr = JSON.stringify(exportData, null, 2);
      navigator.clipboard.writeText(jsonStr).then(() => showToast('Exported & copied!'));
      const blob = new Blob([jsonStr], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${slug || 'blog-post'}-export.json`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });

    // 6. 30-Seconds Auto-save runner
    let lastContent = contentInput.value;
    let lastTitle = titleInput.value;

    setInterval(async () => {
      if (contentInput.value !== lastContent || titleInput.value !== lastTitle) {
        lastContent = contentInput.value;
        lastTitle = titleInput.value;
        await savePost(false, true); 
      }
    }, 30000);

    await loadPostData();
  });
</script>
